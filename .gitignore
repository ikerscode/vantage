dump.rdb

# Env / secrets
infra/.env
.env
.env.local
# Rendered from infra/db-init/01-roles.sql.template by
# scripts/generate_dev_secrets.py — real per-checkout passwords, never
# committed (SEC-02/SEC-04). The .template IS tracked.
infra/db-init/01-roles.sql

# Editors / OS
.vscode/
.idea/
.DS_Store

# Verification run output — real analysis IDs/AOI geometries from dev runs,
