# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / frontend (apps/web)
node_modules/
dist/
.vite/
*.tsbuildinfo
# tsconfig.node.json's composite build (`tsc -b`, part of `npm run build`)
# emits vite.config.js right next to the tracked vite.config.ts — a real
# build byproduct, not source.
apps/web/vite.config.js

# Rust (apps/launcher) — build output only; Cargo.lock IS tracked
# (application crate, reproducible builds matter for the packaged app).
target/

# Celery (apps/api, run locally without a real broker-backed beat schedule store)
celerybeat-schedule.db
celerybeat.pid

# Redis snapshot — dropped in whatever CWD a native (non-container) redis-server
# happened to be started from during local dev; never something to commit.
dump.rdb

# Env / secrets
infra/.env
.env
.env.local
# Rendered from infra/db-init/01-roles.sql.template by
# scripts/generate_dev_secrets.py — real per-checkout passwords, never
# committed (SEC-02/SEC-04). The .template IS tracked.
infra/db-init/01-roles.sql

# Editors / OS
.vscode/
.idea/
.DS_Store

# Verification run output — real analysis IDs/AOI geometries from dev runs,
# not something that should accumulate in git history (SEC-12).
run_artifacts/

# Docker / data volumes bind-mounted locally (none tracked; compose uses named volumes)

# Fine-tuned model weights (BRIEF v1.8) — 165.7MB, over GitHub's 100MB
# per-file push limit without git-lfs. Reproducible via
# scripts/train_vessel_detector/{prepare_dataset,train}.py — see
# VESSEL_DETECTION_REPORT.md. services/inference/weights/README.md (NOT
# ignored) documents this; the directory itself must stay trackable so the
# Dockerfile's directory-level COPY doesn't fail on a checkout that lacks
# the real .pth (default builds only ever use the COCO backend anyway).
services/inference/weights/*.pth

# Training data-prep scratch (BRIEF v1.8) — downloaded annotations + fetched
# Sentinel-2 chips + training artifacts, all real but not meant to live in
# git history; reproducible via prepare_dataset.py/train.py/evaluate.py.
scripts/train_vessel_detector/data/
scripts/train_vessel_detector/.venv/
