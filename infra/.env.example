# Copy to infra/.env before running docker compose. Values here are all
# literal (not composed via nested ${VAR} substitution) since docker compose's
# .env expansion semantics vary by version.

# Postgres. POSTGRES_USER is the bootstrap superuser — used only by the `db`
# image itself and by pgstac-migrate (see infra/db-init/01-roles.sql for why
# that one service is a documented exception). DATABASE_URL (used by
# api/worker/beat) runs as vantage_app instead: DML-only, no DDL rights,
# verified empirically (it can SELECT but gets "permission denied for schema
# public" on CREATE TABLE). api-migrate overrides DATABASE_URL to the
# vantage_migrate role directly in docker-compose.yml, not here.
POSTGRES_DB=vantage
POSTGRES_USER=vantage
POSTGRES_PASSWORD=changeme-dev
DATABASE_URL=postgresql+psycopg://vantage_app:changeme-app-dev@db:5432/vantage

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# MinIO / S3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=vantage-minio
S3_SECRET_ACCESS_KEY=changeme-dev
S3_REGION=us-east-1
S3_BUCKET_ANALYSIS=vantage-analysis
S3_USE_SSL=false
MINIO_ROOT_USER=vantage-minio
MINIO_ROOT_PASSWORD=changeme-dev

# STAC / imagery source — repoint IMAGERY_SOURCE/STAC_API_URL to a local
# catalog for air-gapped deployments once a v2 pgstac-backed source exists.
IMAGERY_SOURCE=earth_search
STAC_API_URL=https://earth-search.aws.element84.com/v1
STAC_DEFAULT_COLLECTION=sentinel-2-l2a

# Auth (dev JWT stub — NOT a real IdP; see apps/api/app/core/security.py).
# The dev user's identity is env-driven rather than a code literal, and every
# token issuance logs a loud warning so this never reads as real auth.
JWT_SECRET=change-me-dev-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=vantage-dev
JWT_AUDIENCE=vantage-api
JWT_EXPIRE_MINUTES=60
DEV_USER_SUB=dev-analyst
DEV_USER_NAME=Dev Analyst
DEV_USER_ROLES=analyst

# Tiler
TILER_BASE_URL=http://tiler:8000
TILER_PUBLIC_BASE_URL=http://localhost:8001

# Tiler GDAL/S3 env (reads public Earth Search COGs via /vsicurl/, and our own
# MinIO output COGs via /vsis3/ using these same AWS_* vars — one process, no
# split needed, see services/tiler/app/main.py)
AWS_S3_ENDPOINT=minio:9000
AWS_ACCESS_KEY_ID=vantage-minio
AWS_SECRET_ACCESS_KEY=changeme-dev
AWS_VIRTUAL_HOSTING=FALSE
AWS_HTTPS=NO
AWS_REGION=us-east-1
# Deliberately NOT setting AWS_NO_SIGN_REQUEST here. It looked like cheap
# insurance for reading Earth Search's public bucket, but it's a global GDAL
# setting that applies to every /vsis3/ request this process makes — and
# /vsis3/ is used exclusively for our OWN private MinIO bucket (Earth Search
# assets are plain https:// hrefs, read via /vsicurl/, which never signs
# requests regardless of this var). Verified empirically during the v1.1
# real-Sentinel-2 run: setting it broke the tiler with a 403 reading our own
# analysis COGs from MinIO, while providing zero benefit for Earth Search
# reads. See RUN_REPORT.md.
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
GDAL_CACHEMAX=200
CPL_VSIL_CURL_CACHE_SIZE=200000000
GDAL_HTTP_MULTIPLEX=YES
GDAL_HTTP_VERSION=2
VSI_CACHE=TRUE
VSI_CACHE_SIZE=5000000
CPL_VSIL_CURL_ALLOWED_EXTENSIONS=.tif,.TIF,.tiff

# Change detection / monitoring
CHANGE_DETECTION_DEFAULT_THRESHOLD=0.2
MONITOR_SWEEP_INTERVAL_SECONDS=300

# Inference (placeholder object detection — torchvision, COCO-pretrained;
# DEVICE=cuda for GPU-ready deployments, no code change needed)
INFERENCE_BASE_URL=http://inference:8000
DEVICE=cpu
MODEL_BACKEND=torchvision_fasterrcnn
SCORE_THRESHOLD=0.5

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
