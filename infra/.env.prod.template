# Template for ${VANTAGE_DATA_DIR}/config/.env — rendered ONCE, at first run,
# by apps/launcher/launcher-core/src/secrets.rs (native Rust, no Python
# runtime dependency in the shipped app). Double-curly-brace tokens below
# are replaced with randomly generated values; nothing here ships as a real
# secret in the repo or in any built image (BRIEF v1.3 §9).
#
# Do not hand-edit the double-curly-brace tokens in THIS file — it's a
# template, not config. The rendered copy in the data dir is the one the app reads, and
# that one IS meant to be hand-editable by an advanced operator (e.g. to
# repoint IMAGERY_SOURCE at an internal catalog).
#
# IMPORTANT: this one rendered file serves double duty. `docker compose`
# only resolves ${VAR} interpolation in the compose YAML itself (image tags,
# port bindings, the ${VANTAGE_DATA_DIR}/config/.env path in every service's
# `env_file:` field) from an explicit `--env-file <path>` flag or a literal
# `.env` next to the compose file — never from a service's own `env_file:`
# block. The launcher must always invoke compose with
# `--env-file ${VANTAGE_DATA_DIR}/config/.env` (see
# apps/launcher/launcher-core/src/compose.rs) so the SAME file supplies both
# compose-level interpolation vars (this section) and container env vars
# (everything below).
VANTAGE_DATA_DIR={{DATA_DIR}}
VANTAGE_API_PORT={{API_PORT}}
VANTAGE_TILER_PORT={{TILER_PORT}}
VANTAGE_DB_PORT={{DB_PORT}}
VANTAGE_API_IMAGE={{API_IMAGE}}
VANTAGE_TILER_IMAGE={{TILER_IMAGE}}
VANTAGE_INFERENCE_IMAGE={{INFERENCE_IMAGE}}

# SEC-04: gates apps/api's fail-closed weak-secret refusal
# (Settings._refuse_weak_production_secrets). Does NOT disable the
# dev-token endpoint (removed in BRIEF v1.6 -- the packaged app has no
# other auth mechanism yet and relies on that stub in every env; see
# apps/api/app/routers/auth.py's own docstring). The packaged app is the
# one place this is genuinely always production.
VANTAGE_ENV=production

# Postgres. POSTGRES_USER is the bootstrap superuser — used only by the `db`
# image itself and by pgstac-migrate, exactly as in dev (see
# infra/db-init/01-roles.sql). VANTAGE_MIGRATE_PASSWORD / the vantage_app
# password below must match infra/db-init-prod/01-roles.sql.template's
# rendering — generate_secrets.py renders both from the same values.
POSTGRES_DB=vantage
POSTGRES_USER=vantage
POSTGRES_PASSWORD={{POSTGRES_PASSWORD}}
DATABASE_URL=postgresql+psycopg://vantage_app:{{VANTAGE_APP_PASSWORD}}@db:5432/vantage
VANTAGE_MIGRATE_PASSWORD={{VANTAGE_MIGRATE_PASSWORD}}

# Redis / Celery. SEC-08: password-protected even though never published on
# a host port — defense in depth against a compromised sibling container.
REDIS_PASSWORD={{REDIS_PASSWORD}}
REDIS_URL=redis://:{{REDIS_PASSWORD}}@redis:6379/0
CELERY_BROKER_URL=redis://:{{REDIS_PASSWORD}}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:{{REDIS_PASSWORD}}@redis:6379/1

# MinIO / S3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=vantage-minio
S3_SECRET_ACCESS_KEY={{MINIO_ROOT_PASSWORD}}
S3_REGION=us-east-1
S3_BUCKET_ANALYSIS=vantage-analysis
S3_USE_SSL=false
MINIO_ROOT_USER=vantage-minio
MINIO_ROOT_PASSWORD={{MINIO_ROOT_PASSWORD}}

# STAC / imagery source. The first-run wizard sets IMAGERY_SOURCE based on
# the operator's chosen imagery mode (BRIEF v1.3 §7): "offline" (default for
# the air-gap installer) -> static_catalog, a real ImagerySource reading the
# bundled demo scenes with zero network calls (see
# apps/api/app/imagery/static_catalog.py and
# apps/api/app/scripts/seed_demo_data.py, the one-shot `demo-seed` compose
# service that pre-populates a demo AOI/monitor/analysis/event so
# Explore/Analyze/Monitor are all populated immediately) — "online" ->
# earth_search (needs internet) — "internal" -> the v2 pgstac seam
# (STAC_API_URL repointed at an internal catalog; imagery ingestion itself
# is still TODO(v2), see CLAUDE.md).
IMAGERY_SOURCE=static_catalog
STAC_API_URL=https://earth-search.aws.element84.com/v1
STAC_DEFAULT_COLLECTION=sentinel-2-l2a
STATIC_CATALOG_MANIFEST_PATH=/data/demo/manifest.json
STATIC_CATALOG_MOUNT_PATH=/data/demo

# Auth (dev JWT stub — NOT a real IdP; see apps/api/app/core/security.py and
# COMPLIANCE.md's single-user-only note). The signing secret is generated
# per-install so no two installs' tokens can ever cross-validate.
JWT_SECRET={{JWT_SECRET}}
JWT_ALGORITHM=HS256
JWT_ISSUER=vantage-desktop
JWT_AUDIENCE=vantage-api
JWT_EXPIRE_MINUTES=60
DEV_USER_SUB=operator
DEV_USER_NAME=Operator
DEV_USER_ROLES=analyst

# BRIEF v1.8: portable alternative to /api/auth/dev-token's loopback-only
# network check, which doesn't generalize across every container runtime
# (confirmed: works under Docker, not under Podman's rootless networking
# -- see apps/api/app/routers/auth.py). The launcher injects this same
# value into the frontend's runtime config; presenting it as a header is
# an ADDITIONAL accepted path, not a replacement for the network check.
DEV_TOKEN_SECRET={{DEV_TOKEN_SECRET}}

# Tiler. SEC-01: shared-secret + host-allowlist — see
# services/tiler/app/security.py, apps/api/app/routers/auth.py's
# /auth/tiler-token endpoint.
TILER_BASE_URL=http://tiler:8000
TILER_PUBLIC_BASE_URL=http://localhost:{{TILER_PORT}}
TILER_TOKEN={{TILER_TOKEN}}
TILER_ALLOWED_HOSTS=earth-search.aws.element84.com,sentinel-cogs.s3.us-west-2.amazonaws.com

# Tiler GDAL/S3 env — identical to infra/.env.example; see that file's
# comments (esp. why AWS_NO_SIGN_REQUEST is deliberately NOT set) for the
# empirically-verified rationale. Unchanged for the packaged deployment.
AWS_S3_ENDPOINT=minio:9000
AWS_ACCESS_KEY_ID=vantage-minio
AWS_SECRET_ACCESS_KEY={{MINIO_ROOT_PASSWORD}}
AWS_VIRTUAL_HOSTING=FALSE
AWS_HTTPS=NO
AWS_REGION=us-east-1
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
GDAL_CACHEMAX=200
CPL_VSIL_CURL_CACHE_SIZE=200000000
GDAL_HTTP_MULTIPLEX=YES
GDAL_HTTP_VERSION=2
VSI_CACHE=TRUE
VSI_CACHE_SIZE=5000000
CPL_VSIL_CURL_ALLOWED_EXTENSIONS=.tif,.TIF,.tiff
GDAL_HTTP_UNSAFESSL=NO
CPL_VSIL_CURL_ALLOWED_FILELIST=
GDAL_SKIP=DODS,NITF,PDF,ECW,JP2ECW,FITS,MSSQLSPATIAL,OGDI

# Change detection / monitoring
CHANGE_DETECTION_DEFAULT_THRESHOLD=0.2
MONITOR_SWEEP_INTERVAL_SECONDS=300

# Inference (object detection). MODEL_BACKEND options (services/inference):
#   torchvision_fasterrcnn         COCO placeholder (default) — resolution-
#     mismatched at Sentinel-2's ~10m/px, so it detects ~nothing on overhead
#     imagery anywhere; "0 detections" is expected, not a fault.
#   torchvision_fasterrcnn_vessel  Fine-tuned "vessel" detector, valid at this
#     GSD — set this for harbor/naval/maritime AOIs (VESSEL_DETECTION_REPORT.md).
# SEC-09: shared secret — see services/inference/app/security.py.
INFERENCE_BASE_URL=http://inference:8000
DEVICE={{INFERENCE_DEVICE}}
MODEL_BACKEND=torchvision_fasterrcnn
SCORE_THRESHOLD=0.5
INFERENCE_TOKEN={{INFERENCE_TOKEN}}

# CORS — the Tauri webview's origin, not a browser dev-server origin. Linux
# and macOS webviews report `tauri://localhost`; the Windows WebView2
# backend reports `http://tauri.localhost`. Both are listed unconditionally
# since this file is the same across OSes and neither origin is reachable
# by anything other than this app's own webview.
CORS_ALLOWED_ORIGINS=tauri://localhost,http://tauri.localhost
